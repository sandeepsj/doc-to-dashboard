VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# TTS backend — 'registry' (default, uses models-registry) or 'local' (read-loud)
VITE_TTS_BACKEND=registry
# Base URL for the models-registry. Default: http://localhost:4100
VITE_REGISTRY_URL=http://localhost:4100
# Registry model id used for TTS. Default: kokoro
VITE_TTS_MODEL=kokoro
